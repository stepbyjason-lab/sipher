# sipher environment variables — put real values in .env.local, never commit it
# (already covered by .gitignore).
# (sipher 환경변수 예시 — 실제 값은 .env.local에 채우고 절대 커밋하지 않는다.)

# --- User language (core/lang.py, round-20) ---
# Default language for OCR prompts & whisper transcription. Leave unset and the
# first run auto-detects your OS locale and writes it to .env.local (e.g. ko, en, ja).
# Edit anytime.
# (OCR 프롬프트·whisper 전사 언어 기본값. 비워두면 첫 실행 때 OS locale을
#  자동감지해 .env.local에 기록. 언제든 직접 수정 가능.)
# SIPHER_LANG=ko

# --- Free vision OCR (core/llm_free.py) ---
# Gemini 2.5 Flash — chosen as the best free vision model in our PoC
# (docs/01-overview.md §8). Get a key at https://aistudio.google.com
# Only needed for the opt-in --ocr flag; without a key OCR degrades honestly
# to "skipped_no_provider".
# (무료 비전 OCR — --ocr 옵트인 시에만 필요. 키 없으면 정직 skip.)
GEMINI_API_KEY=
# Default gemini-2.5-flash (code default when unset / 미지정 시 코드 기본값)
GEMINI_MODEL=gemini-2.5-flash
# Single key only. For higher OCR resilience use the free multi-provider ensemble
# below (add NVIDIA_NIM_API_KEY) — that's within each provider's terms.
# (키는 1개만. OCR 신뢰성은 아래 무료 멀티-provider 앙상블로 — 각 provider 약관 내.)

# --- OCR ensemble (round-24) ---
# Default OCR = free multi-provider ensemble: candidates from Gemini + NVIDIA NIM
# (gemma-4, nemotron) are cross-checked by a free judge (gemma-4). Measured to
# beat single-model OCR on Korean cards. All within each provider's own free tier.
# Get a free NIM key at https://build.nvidia.com (no card). Without it, OCR falls
# back to Gemini alone.
# (기본 OCR = 무료 멀티-provider 앙상블. NIM 키 없으면 Gemini 단독으로 degrade.)
NVIDIA_NIM_API_KEY=
# OCR_MODE=ensemble        # ensemble(기본) | solo(Gemini 단독)
# OCR_PAID_FALLBACK=       # 비우면 무료 소진 시 skip. "claude"면 유료 Claude 폴백(옵트인)
# ANTHROPIC_API_KEY=       # OCR_PAID_FALLBACK=claude 일 때만 필요(유료)

# --- Transcription backend ladder (core/transcribe.py, round-06 local + round-27 Groq) ---
# Order: local whisper first (if configured) -> free Groq Whisper fallback ->
# honest skip. Only needed for the opt-in --transcribe flag.
# (전사 backend 순서: local whisper 우선 -> 무료 Groq Whisper 폴백 -> 정직 skip.
#  --transcribe 옵트인 시에만 필요.)

# Directory of the whisper-transcribe tool (its own .venv + faster-whisper cache).
# Without it, local transcription is unavailable and the ladder falls through to
# Groq (if configured) or degrades to "skipped_no_tool".
# Trust-boundary note: this is a trusted local input — the subprocess executes
# python.exe/transcribe.py under this directory as-is. Re-review before any
# multi-tenant/server deployment (path whitelist etc.).
# (whisper 도구 디렉토리 — 없으면 local이 unavailable로 사다리가 Groq로 내려감.
#  로컬 신뢰 입력이므로 멀티테넌트/서버 배포 시 재검토 필요.)
WHISPER_TRANSCRIBE_DIR=

# Free Groq Whisper fallback (round-27) — used when local whisper is unavailable
# or fails on a given item. Single key only: Groq provides separate free-tier
# buckets per model (whisper-large-v3-turbo -> whisper-large-v3 on 429) within
# that one key — this is not multi-account/multi-key quota rotation. Get a free
# key at https://console.groq.com (no card). Long videos are extracted to audio
# only via local ffmpeg when needed (>25MB or a video container); chunking is
# out of scope.
# (무료 Groq Whisper 폴백 — local이 없거나 개별 아이템에서 실패했을 때만 사용.
#  단일 키 안에서 Groq가 제공하는 모델별 무료 버킷(turbo->v3, 429 시)만 쓴다 —
#  멀티계정/멀티키 우회 아님. 25MB 초과/영상 컨테이너는 로컬 ffmpeg로 오디오만
#  추출 후 업로드. 긴 영상 분할은 비목표.)
GROQ_API_KEY=

# --- Future-round candidates, not wired yet (참고용 — 미배선) ---
# Cloudflare Workers AI (vision/embedding) — dropped in PoC (misreads/hallucination)
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# CF_VISION_MODEL=
# Fast text compression/tagging (unwired)
# CEREBRAS_API_KEY=
